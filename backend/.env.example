# Configuration Base de Données
DATABASE_URL=mysql+pymysql://root:votre_mot_de_passe@localhost/agrigenius_db

# Sécurité (générer une clé secrète aléatoire)
# Pour générer: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=votre_cle_secrete_tres_longue_et_aleatoire_ici

# Configuration JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Configuration Email (pour reset password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
